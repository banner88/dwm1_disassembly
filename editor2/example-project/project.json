    "scripts": [
      { "id": "arm_encounters",
        "comment": "Arms the random-encounter step counter on scroll/post-battle reload (KEY_LESSONS S11: script 0 does NOT run dependably at initial entry; gate/floor are pinned per-step in ASM via bank $71). write_ram writes the LOW byte.",
        "ops": [
          ["op", "write_ram", "0xCA39", "0x0064"],
          ["op", "write_ram", "0xCA3A", "0x0000"],
          ["end"]
        ] },

      { "id": "give_jerky",
        "comment": "Beef Jerky giver — YES/NO, inventory-full branch, GiveItem wrapper opcode $2A",
        "ops": [
          ["text", "jerky_offer"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@declined"],
          ["op", "check_inv_full", "@invFull"],
          ["op", "give_item", "ITEM_BEEF_JERKY"],
          ["text", "jerky_given"],
          ["end"],
          "label:invFull",
          ["text", "inv_full"],
          ["end"],
          "label:declined",
          ["text", "jerky_declined"],
          ["end"]
        ] },

      { "id": "give_egg",
        "comment": "SkyDragon egg giver — AddMonster opcode $29 (enemy_stats_id $015E, same as the Farm event)",
        "ops": [
          ["text", "egg_offer"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@declined"],
          ["op", "check_storage_full", "@storageFull"],
          ["op", "add_monster", "0x015E"],
          ["text", "egg_given"],
          ["end"],
          "label:storageFull",
          ["text", "storage_full"],
          ["end"],
          "label:declined",
          ["text", "egg_declined"],
          ["end"]
        ] },

      { "id": "bgm_change",
        "comment": "SetBGM opcode $41 — VERIFIED 1 param (handler $04:$669D); track $9E = DWM2 BGM #06 port (S62; M3a/S63: bank $74)",
        "ops": [
          ["text", "bgm_q"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@declined"],
          ["op", "set_bgm", "0x009E"],
          ["text", "bgm_changed"],
          ["end"],
          "label:declined",
          ["text", "bgm_declined"],
          ["end"]
        ] },
      { "id": "bgm07_change",
        "comment": "v5/S63: SetBGM $A1 = DWM2 BGM #07 (bank $74 via AudioMasterTableExt)",
        "ops": [
          ["text", "bgm07_q"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@declined"],
          ["op", "set_bgm", "0x00A1"],
          ["text", "bgm07_changed"],
          ["end"],
          "label:declined",
          ["text", "bgm07_declined"],
          ["end"] ] },
      { "id": "first_time_q",
        "ops": [
          ["text", "castle_q"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@noAnswer"],
          ["text", "castle_yes"],
          ["end"],
          "label:noAnswer",
          ["text", "castle_no"],
          ["end"]
        ] },

      { "id": "teleport_castle",
        "comment": "MapTransitionFull opcode $0F to vanilla Castle (params gate/X/Y; transition fires before the trailing end)",
        "ops": [
          ["text", "tp_castle_q"],
          ["op", "check_and_branch", "0xC83C", "0x0001", "@declined"],
